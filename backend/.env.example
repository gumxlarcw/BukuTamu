# Copy this file to ".env" and fill the values.
# Never commit the real ".env" file.

# --- Database ---
DB_HOSTNAME=localhost
DB_USERNAME=root
DB_PASSWORD=your_db_password_here
DB_DATABASE=db_tamdes

# --- CodeIgniter ---
# Generate a long random key, e.g.:
# php -r "echo bin2hex(random_bytes(32)), PHP_EOL;"
CI_ENCRYPTION_KEY=

# --- Admin login (production requires these) ---
ADMIN_USERNAME=admin
# Generate a password hash, e.g.:
# php -r "echo password_hash('ganti_password_ini', PASSWORD_DEFAULT), PHP_EOL;"
ADMIN_PASSWORD_HASH=

# --- JWT (required by Api_base for /api/* auth) ---
# Must be ≥32 chars. Generate with:
# php -r "echo bin2hex(random_bytes(32)), PHP_EOL;"
# If unset, JWT_Helper falls back to a deterministic install-hash and logs an
# error on every request — login still works but is insecure.
JWT_SECRET=

# --- Frontend allowlist (CORS) ---
# Origin of the production React app. Used by Api_base CORS allowlist alongside
# the hardcoded http://localhost:5173 dev origin.
FRONTEND_URL=https://bukutamu.bpsmalut.com

# --- Dashboard PST integration ---
# Endpoint Express server di /opt/newdls/backend/server.js (PM2 'dashboard-pst', port 5001).
# Backend buku tamu mem-proxy panggilan antrian ke URL ini saat operator klik "Panggil"
# di /admin/consultations. WAJIB termasuk path /api/update-antrian.
DASHBOARD_PST_URL=https://dashboard-pst.bpsmalut.com/api/update-antrian

# Catatan: print server tidak via backend lagi — browser kiosk langsung fetch
# ke `http://localhost:5300/print` di komputer kiosk masing-masing.
# Lihat src/hooks/usePrint.ts di frontend.
